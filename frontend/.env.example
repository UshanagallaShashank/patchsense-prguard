# ── Backend API ───────────────────────────────────────────────────────────────
# Production: set to your deployed backend origin (no trailing slash, no /api)
# Leave unset for local dev — Vite proxy handles /api → http://localhost:8000
VITE_API_URL=https://your-backend.onrender.com

# ── Webhook URL ───────────────────────────────────────────────────────────────
# Shown in the settings panel so users know where to point GitHub webhooks.
# Set to your deployed backend origin (the app appends /webhook automatically).
VITE_WEBHOOK_URL=https://your-backend.onrender.com
