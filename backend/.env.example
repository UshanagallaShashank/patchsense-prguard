# ── GitHub App auth ───────────────────────────────────────────────────────────
GITHUB_APP_ID=your_app_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Private key — use one of these two (not both):
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...

# ── GitHub PAT (alternative to App auth for simple deployments) ───────────────
GITHUB_PAT=your_personal_access_token
GITHUB_OWNER=your_github_username_or_org

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SECRET_KEY=your_service_role_secret_key

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── LangSmith tracing ─────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=patchsense-prguard
LANGCHAIN_TRACING_V2=true

# ── Database (only needed for Alembic migrations) ─────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/patchsense

# ── Redis (background job queue) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Docker Compose local DB ───────────────────────────────────────────────────
POSTGRES_PASSWORD=choose_a_local_dev_password

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
REVIEW_TIMEOUT_SECONDS=120

# ── CORS (comma-separated frontend origins) ───────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
